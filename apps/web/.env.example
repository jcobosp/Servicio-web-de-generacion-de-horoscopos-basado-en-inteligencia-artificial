# ============================================================
# CLIENTE (Vite) — solo claves PÚBLICAS
# Copia este archivo a .env.local y rellena los valores reales
# Los secretos del servidor viven en Supabase → Edge Functions → Secrets
# ============================================================

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe (publishable key — la secret va a Edge Functions)
VITE_STRIPE_PUBLISHABLE_KEY=

# Google AdSense (placeholder hasta tener dominio en producción)
VITE_ADSENSE_CLIENT=

# URL del propio sitio
VITE_SITE_URL=http://localhost:5173
