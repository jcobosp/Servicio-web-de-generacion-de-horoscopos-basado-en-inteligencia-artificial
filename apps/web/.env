# ============================================================
# Configuración PÚBLICA del cliente (Vite) — SE VERSIONA A PROPÓSITO.
#
# Contiene SOLO claves públicas: las mismas que viajan dentro del JavaScript
# de la web desplegada (cualquiera las ve en las DevTools del navegador).
# Gracias a esto el repo se clona y arranca SIN configurar nada:
#
#     cd apps/web && npm install && npm run dev
#
# Los SECRETOS del servidor (API key de Gemini, service_role de Supabase y
# secret key de Stripe) NO están aquí ni en el cliente: viven en
# Supabase → Edge Functions → Secrets. Tus datos quedan protegidos por RLS
# y el coste de Gemini está acotado por un límite diario en las funciones.
#
# ¿Quieres apuntar a otro backend en tu máquina? Crea `.env.local`
# (ignorado por git) con tus propios valores; tienen prioridad sobre estos.
# ============================================================

# --- Supabase --------------------------------------------------------------
# La anon key es PÚBLICA por diseño; lo que protege los datos es el RLS, no ocultarla.
VITE_SUPABASE_URL=https://asotgxhniqcdkwainijo.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFzb3RneGhuaXFjZGt3YWluaWpvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzk1NDA4MzYsImV4cCI6MjA5NTExNjgzNn0.ulV3JY_vhamrxTn-qNX9N1nJq0w_sLbWXkqOlFGbM6I

# --- Stripe ----------------------------------------------------------------
# El cliente NO usa esta clave: el checkout se inicia en una Edge Function que
# redirige a la página alojada de Stripe. El backend está en modo PRUEBA, así que
# el flujo premium se prueba con tarjetas de test (4242 4242 4242 4242), sin pagos reales.
VITE_STRIPE_PUBLISHABLE_KEY=

# --- Google AdSense --------------------------------------------------------
# Vacío en local. El script solo se carga en producción y con consentimiento del usuario.
VITE_ADSENSE_CLIENT=

# --- Google Analytics ------------------------------------------------------
# Vacío = no se carga ninguna analítica.
VITE_GA_ID=

# --- URL del propio sitio --------------------------------------------------
VITE_SITE_URL=http://localhost:5173
